@page "{id:int}"
@model MusicAlbums.Pages.Albums.EditModel

<h1>Edit Album</h1>

<form method="post">
    <input type="hidden" asp-for="Album.Id" />
    <div>
        <label asp-for="Album.Title"></label>
        <input asp-for="Album.Title" />
        <span asp-validation-for="Album.Title"></span>
    </div>
    <div>
        <label asp-for="Album.Artist"></label>
        <input asp-for="Album.Artist" />
        <span asp-validation-for="Album.Artist"></span>
    </div>
    <div>
        <label asp-for="Album.Year"></label>
        <input asp-for="Album.Year" />
        <span asp-validation-for="Album.Year"></span>
    </div>
    <div>
        <label asp-for="Album.Genre"></label>
        <input asp-for="Album.Genre" />
        <span asp-validation-for="Album.Genre"></span>
    </div>
    <button type="submit">Save</button>
</form>

<a asp-page="Index">Back to List</a>