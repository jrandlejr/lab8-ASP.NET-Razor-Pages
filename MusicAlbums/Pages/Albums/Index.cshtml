@page
@model MusicAlbums.Pages.Albums.IndexModel

<h1>My Favorite Music Albums</h1>

<p>
    <a asp-page="Create">Add New Album</a>
</p>

<table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Artist</th>
            <th>Year</th>
            <th>Genre</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var album in Model.Albums)
        {
            <tr>
                <td>@album.Title</td>
                <td>@album.Artist</td>
                <td>@album.Year</td>
                <td>@album.Genre</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@album.Id">Edit</a>
                    <a asp-page="Details" asp-route-id="@album.Id">Details</a>
                    <a asp-page="Delete" asp-route-id="@album.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>